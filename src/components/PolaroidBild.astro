---
// Bild im Vorlagen-Stil:
// - "polaroid": weißer Rahmen, leicht gedreht (Welcome-Sektion)
// - "versatz":  weißer Rahmen mit versetztem Altrosé-Farbblock dahinter (About-Sektion)
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  variant?: 'polaroid' | 'versatz';
  rotate?: number;
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  variant = 'polaroid',
  rotate = -2.5,
  widths = [420, 840],
  sizes = '(max-width: 780px) 86vw, 420px',
  loading = 'lazy',
} = Astro.props;
---

<div class={`bild bild--${variant}`} style={`--drehung:${rotate}deg`}>
  {variant === 'versatz' && <span class="versatz-block" aria-hidden="true"></span>}
  <span class="rahmen">
    <Image src={src} alt={alt} widths={widths} sizes={sizes} loading={loading} />
  </span>
</div>

<style>
  .bild {
    position: relative;
    display: block;
    max-width: 100%;
  }

  .rahmen {
    display: block;
    position: relative;
    background: var(--weiss);
    padding: clamp(8px, 1.3vw, 13px);
    border-radius: 2px;
    box-shadow: var(--schatten-weich);
  }

  .rahmen :global(img) {
    width: 100%;
    border-radius: 1px;
  }

  .bild--polaroid .rahmen {
    transform: rotate(var(--drehung));
    transition: transform 0.4s ease;
  }

  .bild--polaroid:hover .rahmen {
    transform: rotate(calc(var(--drehung) * 0.4));
  }

  .versatz-block {
    position: absolute;
    inset: 0;
    transform: translate(clamp(10px, 2vw, 18px), clamp(10px, 2vw, 18px));
    background: var(--altrose);
    border-radius: 2px;
  }
</style>
