---
// Fußzeile: rechtliche Links, Pinterest, Copyright-Zeile aus den Einstellungen
// und die Versionsnummer (Single Source: package.json).
import { getSiteSettings } from '../lib/settings';
import { withBase } from '../lib/url';
import pkg from '../../package.json';

const site = await getSiteSettings();
const jahr = new Date().getFullYear();
const footerText = site.footerText.replaceAll('{jahr}', String(jahr));
---

<footer class="site-footer">
  <div class="container footer-inner">
    <nav class="footer-nav" aria-label="Fußzeilen-Navigation">
      <a href={withBase('/suche')}>Suche</a>
      <a href={withBase('/impressum')}>Impressum</a>
      <a href={withBase('/datenschutz')}>Datenschutz</a>
      <a href={withBase('/newsletter')}>Newsletter</a>
      <a href={withBase('/rss.xml')}>RSS</a>
      {
        site.pinterestUrl && (
          <a href={site.pinterestUrl} target="_blank" rel="noopener noreferrer">
            Pinterest
          </a>
        )
      }
    </nav>
    <p class="footer-text">{footerText}</p>
    <p class="footer-version">Version {pkg.version}</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: clamp(56px, 8vw, 100px);
    border-top: 1px solid rgba(58, 58, 58, 0.1);
    background: var(--creme);
  }

  .footer-inner {
    padding-block: 36px 30px;
    text-align: center;
  }

  .footer-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(16px, 3vw, 32px);
    margin-bottom: 16px;
  }

  .footer-nav a {
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--anthrazit);
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--salbei-tief);
  }

  .footer-text {
    font-size: 13.5px;
    color: var(--text-muted);
    margin: 0 0 4px;
  }

  .footer-version {
    font-size: 11px;
    color: var(--text-muted);
    opacity: 0.7;
    margin: 0;
  }
</style>
