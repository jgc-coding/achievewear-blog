---
// Grund-Layout aller Seiten: <head> (SEO, noindex-Schalter, Fonts, Farb-Variablen
// aus den CMS-Einstellungen), Header und Footer.
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/500-italic.css';
import '@fontsource/great-vibes/400.css';
import '../styles/global.css';
import { getImage } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import YouTubeConsent from '../components/YouTubeConsent.astro';
import { getSiteSettings, getDesign } from '../lib/settings';
import { withBase } from '../lib/url';
// Standard-Teilen-Bild. Design-Quelle ist og-standard.svg — Astros Bild-Service
// rastert importierte SVGs nicht zu PNG, deshalb liegt das gerasterte PNG mit im
// Repo. Nach einer Änderung am SVG das PNG neu rastern (im Projekt-Root):
// node -e "require('sharp')('src/assets/og-standard.svg').resize(1200,630).png().toFile('src/assets/og-standard.png').then(i => console.log(i.width + 'x' + i.height))"
import ogStandardPng from '../assets/og-standard.png';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description, ogImage, ogType = 'website' } = Astro.props;
const site = await getSiteSettings();
const design = await getDesign();

const fullTitle = title ? `${title} · ${site.title}` : `${site.title} — ${site.tagline}`;
const metaDescription = description ?? site.description;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;

// Fallback-Teilen-Bild für alle Seiten ohne eigenes: Standard-PNG durch die
// Bild-Pipeline schicken (format explizit, sonst würde Astro zu WebP wandeln —
// og:image braucht das breit unterstützte PNG) und wie in blog/[slug].astro
// absolut machen. Setzt eine Seite die ogImage-Prop, hat diese Vorrang.
const ogStandardBild = await getImage({ src: ogStandardPng, width: 1200, format: 'png' });
const ogImageFallback = Astro.site ? new URL(ogStandardBild.src, Astro.site).href : undefined;
const ogImageFinal = ogImage ?? ogImageFallback;

// Farbpalette aus design.yml als CSS-Variablen (Lisa kann sie im CMS ändern)
const cssVars =
  `:root{--creme:${design.creme};--rosa-zart:${design.rosaZart};--mint:${design.mint};` +
  `--salbei:${design.salbei};--anthrazit:${design.anthrazit};--salbei-tief:${design.salbeiTief};` +
  `--altrose:${design.altrose};--altrose-dunkel:${design.altroseDunkel};--weiss:${design.weiss};}`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    {site.noindex && <meta name="robots" content="noindex, nofollow" />}
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={site.title}
      href={withBase('/rss.xml')}
    />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="de_DE" />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImageFinal && <meta property="og:image" content={ogImageFinal} />}
    <meta name="twitter:card" content="summary_large_image" />
    <style set:html={cssVars}></style>
    <script is:inline>
      // Kennzeichnet, dass JavaScript läuft — erst dann werden Einblend-Effekte aktiviert.
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#inhalt">Zum Inhalt springen</a>
    <Header />
    <main id="inhalt">
      <slot />
    </main>
    <Footer />
    <!-- Video-Boxen können in jedem Markdown-Inhalt vorkommen — Artikel wie feste Seiten. -->
    <YouTubeConsent />
    <script>
      // Sanftes Einblenden der Sektionen beim Scrollen (respektiert prefers-reduced-motion via CSS).
      const beobachter = new IntersectionObserver(
        (eintraege) => {
          for (const eintrag of eintraege) {
            if (eintrag.isIntersecting) {
              eintrag.target.classList.add('sichtbar');
              beobachter.unobserve(eintrag.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.fade-up').forEach((el) => beobachter.observe(el));
    </script>
  </body>
</html>
