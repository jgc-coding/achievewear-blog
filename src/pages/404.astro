---
// 404-Seite — GitHub Pages und All-Inkl liefern dist/404.html automatisch aus.
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/url';
---

<BaseLayout title="Seite nicht gefunden">
  <div class="container nicht-gefunden">
    <p class="script code">Ups …</p>
    <h1>Diese Seite gibt es (noch) nicht.</h1>
    <p class="hinweis">
      Vielleicht hat sich der Link vertippt — oder die Seite ist umgezogen.
      Kein Grund zur Eile: Der Weg zurück ist nur einen Klick entfernt.
    </p>
    <a class="btn" href={withBase('/')}>Zur Startseite</a>
  </div>
</BaseLayout>

<style>
  .nicht-gefunden {
    text-align: center;
    padding-top: clamp(48px, 8vw, 100px);
    max-width: 640px;
  }

  .code {
    font-size: clamp(44px, 7vw, 64px);
    margin: 0;
    line-height: 1.1;
  }

  h1 {
    font-size: clamp(28px, 4vw, 40px);
    letter-spacing: 0.05em;
  }

  .hinweis {
    color: var(--text-muted);
    margin-bottom: 28px;
  }
</style>
