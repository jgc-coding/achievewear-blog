---
// Statische Seiten aus der Collection "seiten": Über mich, Impressum,
// Datenschutz, Newsletter. Die Newsletter-Seite zeigt zusätzlich den
// Anmelde-Knopf, sobald in den Einstellungen ein MailerLite-Link hinterlegt ist.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteSettings } from '../lib/settings';

export async function getStaticPaths() {
  const seiten = await getCollection('seiten');
  return seiten.map((seite) => ({ params: { slug: seite.id }, props: { seite } }));
}

const { seite } = Astro.props;
const { Content } = await render(seite);
const site = await getSiteSettings();

const zeigeNewsletterKnopf = seite.id === 'newsletter' && site.newsletterUrl;
---

<BaseLayout title={seite.data.title} description={seite.data.description}>
  <article class="container seite">
    <header class="seiten-kopf">
      <h1>{seite.data.title}</h1>
      <span class="mini-linie" aria-hidden="true"></span>
    </header>
    <div class="prose">
      <Content />
    </div>
    {
      zeigeNewsletterKnopf && (
        <p class="newsletter-aktion">
          <a class="btn" href={site.newsletterUrl} target="_blank" rel="noopener noreferrer">
            Zur Newsletter-Anmeldung
          </a>
        </p>
      )
    }
  </article>
</BaseLayout>

<style>
  .seite {
    max-width: 760px;
    padding-top: clamp(26px, 4vw, 48px);
  }

  .seiten-kopf {
    margin-bottom: clamp(28px, 4vw, 40px);
  }

  .seiten-kopf h1 {
    font-size: clamp(34px, 5vw, 48px);
    letter-spacing: 0.06em;
    margin-bottom: 14px;
  }

  .newsletter-aktion {
    margin-top: 32px;
  }
</style>
