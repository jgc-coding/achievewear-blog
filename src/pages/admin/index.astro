---
// Redaktionsbereich (Sveltia CMS) — bewusst OHNE BaseLayout: eine eigene,
// minimale HTML-Hülle. Das CMS wird lokal gebundelt (DSGVO: kein CDN).
// Konfiguration: public/admin/config.yml
import { withBase } from '../../lib/url';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>AchieveWear · Redaktion</title>
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="cms-config-url" type="application/yaml" href={withBase('/admin/config.yml')} />
  </head>
  <body>
    <script>
      import { init } from '@sveltia/cms';
      init();
    </script>
  </body>
</html>
