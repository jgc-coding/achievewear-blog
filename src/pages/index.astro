---
// Startseite nach der "Modern Bohemian"-Vorlage in der AchieveWear-Farbwelt:
// Welcome (Rosa-Band + Polaroid) · Über mich (Mint-Band + Versatz-Bild) ·
// Aus dem Blog (3 Kategorie-Karten) · Zitat-Band · Newsletter-Band.
// Alle Texte und Bilder kommen aus einstellungen/startseite.yml (im CMS änderbar).
import BaseLayout from '../layouts/BaseLayout.astro';
import SektionsTitel from '../components/SektionsTitel.astro';
import PolaroidBild from '../components/PolaroidBild.astro';
import { Image } from 'astro:assets';
import { getStartseite, getKategorien, getSiteSettings } from '../lib/settings';
import { withBase, linkUrl } from '../lib/url';

const start = await getStartseite();
const kategorien = await getKategorien();
const site = await getSiteSettings();
const newsletterZiel = site.newsletterUrl || withBase('/newsletter');
---

<BaseLayout>
  <!-- ===== Welcome ===== -->
  <section class="welcome">
    <div class="container">
      <div class="welcome-band fade-up">
        <div class="welcome-bild">
          <PolaroidBild
            src={start.welcome.image}
            alt={start.welcome.imageAlt}
            variant="polaroid"
            loading="eager"
          />
        </div>
        <div class="welcome-text">
          <h1 class="welcome-headline">{start.welcome.headline}</h1>
          <p class="script welcome-script">{start.welcome.scriptLine}</p>
          <span class="mini-linie" aria-hidden="true"></span>
          <p class="welcome-copy">{start.welcome.text}</p>
          <a class="btn" href={linkUrl(start.welcome.buttonUrl)}>{start.welcome.buttonText}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Über mich ===== -->
  <section class="about">
    <div class="container about-grid">
      <div class="about-text fade-up">
        <SektionsTitel text={start.about.headline} script={start.about.scriptLine} align="left" />
        <p class="about-copy">{start.about.text}</p>
        <a class="btn btn--outline" href={linkUrl(start.about.buttonUrl)}>
          {start.about.buttonText}
        </a>
      </div>
      <div class="about-bild fade-up">
        <PolaroidBild src={start.about.image} alt={start.about.imageAlt} variant="versatz" />
      </div>
    </div>
  </section>

  <!-- ===== Aus dem Blog: die drei Säulen ===== -->
  <section class="blog-vorschau">
    <div class="container">
      <div class="fade-up">
        <SektionsTitel
          text={start.blogSection.headline}
          script={start.blogSection.scriptLine}
        />
      </div>
      <div class="kategorie-grid">
        {
          kategorien.map((kategorie, index) => (
            <a
              class="kategorie-karte fade-up"
              href={withBase(`/kategorie/${kategorie.slug}`)}
              style={`--karten-farbe:${kategorie.color};--verzoegerung:${index * 0.12}s`}
            >
              <span class="kategorie-label script" aria-hidden="true">
                {kategorie.name}
              </span>
              <span class="kategorie-rahmen">
                <Image
                  src={kategorie.image}
                  alt={kategorie.imageAlt}
                  widths={[340, 680]}
                  sizes="(max-width: 780px) 86vw, 320px"
                />
              </span>
              <span class="kategorie-name">{kategorie.name}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== Zitat ===== -->
  <section class="zitat">
    <div class="container zitat-inner fade-up">
      <span class="zitat-zeichen" aria-hidden="true">&ldquo;</span>
      <blockquote>
        <p class="zitat-text">{start.quote.text}</p>
        <cite class="script zitat-attribution">{start.quote.attribution}</cite>
      </blockquote>
    </div>
  </section>

  <!-- ===== Newsletter ===== -->
  {
    start.newsletter.show && (
      <section class="newsletter">
        <div class="container">
          <div class="newsletter-band fade-up">
            <p class="script newsletter-headline">{start.newsletter.headline}</p>
            <p class="newsletter-text">{start.newsletter.text}</p>
            <a class="btn" href={newsletterZiel}>
              {start.newsletter.buttonText}
            </a>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  /* ---------- Welcome ---------- */
  .welcome {
    padding-top: clamp(70px, 9vw, 110px);
  }

  .welcome-band {
    background: var(--rosa-zart);
    border-radius: 4px;
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
    padding: clamp(28px, 5vw, 60px) clamp(22px, 5vw, 64px);
  }

  .welcome-bild {
    margin-top: clamp(-70px, -8vw, -100px);
    max-width: 400px;
    justify-self: center;
  }

  .welcome-headline {
    font-size: clamp(38px, 6vw, 62px);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
  }

  .welcome-script {
    font-size: clamp(30px, 4vw, 42px);
    line-height: 1.15;
    margin: 2px 0 0;
  }

  .welcome-text .mini-linie {
    margin: 18px 0 20px;
  }

  .welcome-copy {
    max-width: 46ch;
    color: var(--text-muted);
    margin-bottom: 26px;
  }

  /* ---------- Über mich ---------- */
  .about {
    margin-top: clamp(64px, 9vw, 120px);
    background: var(--mint);
    padding-block: clamp(48px, 7vw, 80px);
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: clamp(28px, 6vw, 72px);
    align-items: center;
  }

  .about-copy {
    max-width: 50ch;
    color: var(--text-muted);
    margin-bottom: 26px;
  }

  .about-bild {
    max-width: 380px;
    justify-self: center;
    margin-block: clamp(-90px, -7vw, -60px);
  }

  /* ---------- Aus dem Blog ---------- */
  .blog-vorschau {
    padding-top: clamp(110px, 13vw, 160px);
  }

  .kategorie-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(24px, 4.5vw, 56px);
    padding-inline: clamp(0px, 3vw, 36px);
  }

  .kategorie-karte {
    position: relative;
    display: block;
    text-decoration: none;
    padding-left: 26px;
    transition: transform 0.35s ease;
    transition-delay: var(--verzoegerung, 0s);
  }

  .kategorie-karte:hover {
    transform: translateY(-8px);
  }

  .kategorie-label {
    position: absolute;
    left: -6px;
    bottom: 40px;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: clamp(30px, 3.4vw, 40px);
    color: var(--karten-farbe, var(--salbei));
    line-height: 1;
    z-index: 1;
    pointer-events: none;
  }

  .kategorie-rahmen {
    display: block;
    background: var(--weiss);
    padding: 9px;
    border-radius: 2px;
    box-shadow: var(--schatten-weich);
    transition: box-shadow 0.35s ease;
  }

  .kategorie-karte:hover .kategorie-rahmen {
    box-shadow: 0 22px 44px rgba(58, 58, 58, 0.16);
  }

  .kategorie-rahmen :global(img) {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .kategorie-name {
    display: block;
    margin-top: 14px;
    text-align: center;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--anthrazit);
  }

  /* ---------- Zitat ---------- */
  .zitat {
    margin-top: clamp(72px, 10vw, 130px);
    background: var(--rosa-zart);
    padding-block: clamp(56px, 8vw, 90px);
  }

  .zitat-inner {
    position: relative;
    max-width: 760px;
    text-align: center;
  }

  .zitat-zeichen {
    position: absolute;
    top: -0.55em;
    left: clamp(4px, 4vw, 40px);
    font-family: var(--font-serif);
    font-size: clamp(130px, 18vw, 190px);
    line-height: 1;
    color: var(--weiss);
    opacity: 0.85;
    pointer-events: none;
  }

  blockquote {
    margin: 0;
    position: relative;
  }

  .zitat-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(20px, 2.8vw, 27px);
    line-height: 1.55;
    color: var(--anthrazit);
    margin: 0 auto 14px;
    max-width: 34em;
  }

  .zitat-attribution {
    font-style: normal;
    font-size: clamp(26px, 3vw, 32px);
  }

  /* ---------- Newsletter ---------- */
  .newsletter {
    padding-top: clamp(64px, 9vw, 110px);
  }

  .newsletter-band {
    background: var(--mint);
    border-radius: 4px;
    text-align: center;
    padding: clamp(40px, 6vw, 64px) clamp(22px, 5vw, 64px);
  }

  .newsletter-headline {
    font-size: clamp(34px, 4.4vw, 46px);
    color: var(--salbei-tief);
    margin: 0 0 10px;
    line-height: 1.15;
  }

  .newsletter-text {
    max-width: 52ch;
    margin: 0 auto 24px;
    color: var(--text-muted);
  }

  /* ---------- Mobil ---------- */
  @media (max-width: 780px) {
    .welcome {
      padding-top: 46px;
    }

    .welcome-band,
    .about-grid {
      grid-template-columns: 1fr;
    }

    .welcome-bild {
      margin-top: -46px;
      max-width: 300px;
    }

    .welcome-text {
      text-align: center;
    }

    .welcome-text .mini-linie {
      margin-inline: auto;
    }

    .welcome-copy {
      margin-inline: auto;
    }

    .about-bild {
      margin-block: 0;
      max-width: 300px;
      order: -1;
    }

    .about-text {
      text-align: center;
    }

    .about-text :global(.script-zeile),
    .about-text :global(.titel) {
      justify-content: center;
      text-align: center;
    }

    .about-copy {
      margin-inline: auto;
    }

    .blog-vorschau {
      padding-top: 72px;
    }

    .kategorie-grid {
      grid-template-columns: 1fr;
      max-width: 340px;
      margin-inline: auto;
      gap: 40px;
    }
  }
</style>
